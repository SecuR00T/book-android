<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="BookVillage"
        android:usesCleartextTraffic="true"
        android:debuggable="true"
        android:theme="@style/Theme.BookVillageMock">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: bookvillage scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bookvillage" />
            </intent-filter>

            <!-- Deep link: http/https -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" android:host="bookvillage.local" />
                <data android:scheme="https" android:host="bookvillage.local" />
            </intent-filter>
        </activity>

        <!-- Exported activity for viewing user profile without authentication -->
        <activity
            android:name=".ProfileActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bookvillage" android:host="profile" />
            </intent-filter>
        </activity>

        <!-- Exported activity for order details without authentication -->
        <activity
            android:name=".OrderActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bookvillage" android:host="order" />
            </intent-filter>
        </activity>

        <!--
            CTF 취약점: 관리자 패널 딥링크 - 디컴파일 시 발견 가능
            apktool / jadx 로 AndroidManifest.xml 분석 시 노출됨

            진입 방법 (디컴파일 후 발견):
              adb shell am start -W \
                -a android.intent.action.VIEW \
                -d "bookvillage://admin-panel" \
                com.bookvillage.mock
        -->
        <activity
            android:name=".AdminPanelActivity"
            android:exported="true"
            android:label="관리자 패널"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="bookvillage" android:host="admin-panel" />
            </intent-filter>
        </activity>

        <!--
            CTF Challenge 1 & 2: Smali 분석 대상 Activity
            apktool로 디컴파일 후 manifest에서 발견

            Challenge 1 (Magic Number):
              adb shell am start \
                -n com.bookvillage.mock/.AdminGateActivity \
                - -ei gate_key <smali에서_계산한_값>

            Challenge 2 (Smali 패치):
              apktool d app.apk
              → AdminGateActivity.smali에서 isDebugMode 필드 패치
              → apktool b / 재서명 / 재설치
        -->
        <activity
            android:name=".AdminGateActivity"
            android:exported="true"
            android:label="" />

        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>
